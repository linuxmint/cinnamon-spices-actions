#. text.py:14
msgid "Install fonts"
msgstr "Instalar fontes"

#. text.py:16
msgid "Fonts were installed successfuly!"
msgstr "Fontes instaladas com sucesso!"

#. text.py:18
msgid "Fonts could not be installed!"
msgstr "Não foi possível instalar as fontes!"

#. text.py:20
msgid "Some fonts could not be installed!"
msgstr "Algumas fontes não puderam ser instaladas!"

#. text.py:22
msgid "Updating fonts cache..."
msgstr "Atualizando o cache de fontes..."

#. text.py:25
msgid ""
"Could not update fonts cache.\n"
"The installation of the fonts may not take immediate effect."
msgstr ""
"Não foi possível atualizar o cache de fontes.\n"
"A instalação pode não surtir efeito imediatamente."

#. text.py:29
msgid "Post installation issues"
msgstr "Problemas pós-instalação"

#. text.py:32
msgid ""
"Some similar fonts are already installed.\n"
"What should be done in this case?"
msgstr ""
"Fontes semelhantes já estão instaladas.\n"
"O que deseja fazer neste caso?"

#. text.py:35
msgid "Cancel"
msgstr "Cancelar"

#. text.py:37
msgid "Ignore"
msgstr "Ignorar"

#. text.py:39
msgid "Override"
msgstr "Substituir"

#. metadata.json->description
#. install-fonts@anaximeno.nemo_action.in->Comment
msgid "Install selected fonts to your system account."
msgstr "Instala as fontes selecionadas na sua conta de usuário."
